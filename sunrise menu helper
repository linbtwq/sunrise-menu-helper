
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>sunrise menu helper</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: clamp(12px, 2.5vw, 24px);
            min-height: 100svh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #080611 0%, #1a1034 45%, #2b1e4f 100%);
            background-size: 220% 220%;
            animation: gradientBG 16s ease infinite;
            color: #ffffff;
            box-sizing: border-box;
            overflow-x: hidden;
            position: relative;
            transform: translateZ(0);
            will-change: transform;
        }

        body::before,
        body::after {
            content: '';
            position: fixed;
            border-radius: 50%;
            filter: blur(70px);
            opacity: 0.35;
            pointer-events: none;
            z-index: 0;
        }

        body::before {
            width: 260px;
            height: 260px;
            background: #ff4d7a;
            top: -70px;
            right: -60px;
        }

        body::after {
            width: 220px;
            height: 220px;
            background: #4facfe;
            bottom: -60px;
            left: -40px;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .app-container {
            background: rgba(10, 12, 24, 0.72);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 28px;
            padding: clamp(20px, 4vw, 40px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
            max-width: 900px;
            width: 100%;
            text-align: center;
            position: relative;
            overflow: hidden;
            z-index: 1;
            transform: translateZ(0);
            backface-visibility: hidden;
            contain: layout paint;
        }

        .app-container::before {
            content: '';
            position: absolute;
            top: -80px;
            left: -70px;
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(233,69,96,0.35) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(25px);
            z-index: 0;
        }

        .app-container::after {
            content: '';
            position: absolute;
            bottom: -70px;
            right: -70px;
            width: 240px;
            height: 240px;
            background: radial-gradient(circle, rgba(79,172,254,0.28) 0%, transparent 72%);
            border-radius: 50%;
            filter: blur(28px);
            z-index: 0;
        }

        /* ТЕКСТИ І ЗАГОЛОВКИ */
        h1, h2, p, div { position: relative; z-index: 1; }
        
        h1 {
            font-size: clamp(28px, 4.4vw, 42px);
            font-weight: 800;
            background: linear-gradient(90deg, #ff8a00, #e52e71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0 0 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h2 {
            font-size: 24px;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
            display: inline-block;
            padding: 10px 18px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
        }

        p.subtitle {
            color: #c7c7d4;
            font-size: 16px;
            margin: 0 auto 30px;
            max-width: 700px;
            line-height: 1.6;
        }

        .grid-menu {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
        }

        .category-btn {
            background: linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: #fff;
            padding: 22px 16px;
            border-radius: 18px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.35s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
            min-height: 92px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 24px rgba(0,0,0,0.2);
        }

        .category-btn::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: all 0.5s;
        }

        .category-btn:hover {
            transform: translateY(-4px) scale(1.01);
            background: linear-gradient(145deg, rgba(233,69,96,0.16), rgba(255,138,0,0.12));
            border-color: #ff7b7b;
            box-shadow: 0 12px 24px rgba(255, 74, 109, 0.18), inset 0 0 14px rgba(255,255,255,0.04);
            color: #ffe7ef;
        }

        .category-btn:hover::after { left: 100%; }

        .progress-container {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            margin: 20px 0 30px 0;
            overflow: hidden;
            position: relative;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #ff8a00, #e52e71);
            border-radius: 10px;
            transition: width 0.5s ease-out;
            box-shadow: 0 0 10px #e52e71;
        }

        #progress-text {
            color: #aaa;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        #question-text {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 30px;
            line-height: 1.4;
            text-shadow: 0 2px 10px rgba(0,0,0,0.5);
        }

        .options { display: flex; flex-direction: column; gap: 15px; margin-bottom: 30px; }

        .option-btn {
            background: linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.12);
            padding: 16px 18px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 15px;
            font-family: inherit;
            line-height: 1.55;
            text-align: left;
            transition: all 0.3s ease;
            position: relative;
            box-shadow: 0 8px 18px rgba(0,0,0,0.16);
        }

        .option-btn:hover {
            background: rgba(255, 255, 255, 0.12);
            border-color: #ff8a00;
            box-shadow: 0 8px 18px rgba(255, 138, 0, 0.14);
            transform: translateY(-2px);
        }

        #score-display {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(90deg, #00f2fe, #4facfe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 20px 0;
            filter: drop-shadow(0px 4px 10px rgba(79, 172, 254, 0.4));
        }

        .score-message { font-size: 20px; color: #fff; font-weight: 600; margin-bottom: 30px; }

        .action-btn {
            background: linear-gradient(135deg, #ff5f7e, #ff2a5f);
            color: #fff;
            border: none;
            padding: 14px 24px;
            border-radius: 999px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin: 8px;
            box-shadow: 0 10px 24px rgba(233, 69, 96, 0.34);
        }

        .action-btn:hover {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 10px 22px rgba(233, 69, 96, 0.34);
        }

        .hidden { display: none !important; }

        .fade-in {
            animation: fadeIn 0.35s cubic-bezier(0.22, 1, 0.36, 1);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .category-btn {
            animation: fadeIn 0.35s ease backwards;
        }

        .category-btn:nth-child(2) { animation-delay: 0.04s; }
        .category-btn:nth-child(3) { animation-delay: 0.08s; }
        .category-btn:nth-child(4) { animation-delay: 0.12s; }
        .category-btn:nth-child(5) { animation-delay: 0.16s; }
        .category-btn:nth-child(6) { animation-delay: 0.20s; }
        .category-btn:nth-child(7) { animation-delay: 0.24s; }

        .option-btn {
            animation: fadeIn 0.28s ease backwards;
        }

        .option-btn:nth-child(2) { animation-delay: 0.04s; }
        .option-btn:nth-child(3) { animation-delay: 0.08s; }
        .option-btn:nth-child(4) { animation-delay: 0.12s; }
        .option-btn:nth-child(5) { animation-delay: 0.16s; }

        .category-btn:active,
        .option-btn:active,
        .action-btn:active {
            transform: scale(0.98);
        }

        .category-btn,
        .option-btn,
        .action-btn {
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
            will-change: transform, opacity;
        }

        .category-btn,
        .option-btn,
        .action-btn,
        .app-container {
            transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, opacity 0.25s ease;
        }

        @media (max-width: 768px) {
            body {
                padding: 12px;
                align-items: flex-start;
                animation: none;
            }

            body::before,
            body::after {
                opacity: 0.2;
                filter: blur(40px);
            }

            .app-container {
                padding: 22px 16px;
                border-radius: 20px;
                backdrop-filter: none;
                -webkit-backdrop-filter: none;
            }

            h2 {
                font-size: 20px;
                padding: 8px 14px;
            }

            #question-text {
                font-size: 20px;
            }

            .grid-menu {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 12px;
            }

            .category-btn {
                padding: 16px 12px;
                font-size: 13px;
                min-height: 84px;
            }

            .option-btn {
                padding: 14px;
                font-size: 15px;
            }

            .action-btn {
                width: 100%;
                margin: 8px 0;
                padding: 14px 20px;
            }

            .category-btn:hover,
            .option-btn:hover,
            .action-btn:hover {
                transform: none;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 8px;
            }

            .app-container {
                padding: 16px 12px;
            }

            .grid-menu {
                grid-template-columns: 1fr;
            }

            .category-btn,
            .option-btn,
            .action-btn {
                border-radius: 12px;
            }

            p.subtitle {
                font-size: 14px;
                margin-bottom: 20px;
            }

            #question-text {
                font-size: 18px;
                margin-bottom: 20px;
            }

            .options {
                gap: 10px;
                margin-bottom: 20px;
            }

            #score-display {
                font-size: 36px;
            }

            .score-message {
                font-size: 16px;
            }
        }
    </style>
</head>
