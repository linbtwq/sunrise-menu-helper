        let currentCategoryKey = null;
        let generatedQuestions = [];
        let questionIndex = 0;
        let score = 0;

        const screens = {
            menu: document.getElementById('main-menu'),
            quiz: document.getElementById('quiz-screen'),
            result: document.getElementById('result-screen')
        };

        function hideAllScreens() {
            Object.values(screens).forEach(screen => {
                screen.classList.add('hidden');
                screen.classList.remove('fade-in');
            });
        }

        function showMainMenu() {
            hideAllScreens();
            screens.menu.classList.remove('hidden');
            setTimeout(() => screens.menu.classList.add('fade-in'), 10);
        }

        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        function generateQuizData(categoryKey) {
            const items = rawMenuData[categoryKey].items;
            let questions = [];

            items.forEach(item => {
                let options = [item.desc]; 
                let wrongOptions = [];
                let attempts = 0;
                while (wrongOptions.length < 2 && attempts < 50) {
                    let randomItem = items[Math.floor(Math.random() * items.length)];
                    if (randomItem.desc !== item.desc && !wrongOptions.includes(randomItem.desc)) {
                        wrongOptions.push(randomItem.desc);
                    }
                    attempts++;
                }

                options = options.concat(wrongOptions);
                options = shuffleArray(options); 
                let correctIndex = options.indexOf(item.desc);

                questions.push({
                    question: `Що входить до складу страви «${item.name}»?`,
                    options: options,
                    correct: correctIndex
                });
            });
            return shuffleArray(questions);
        }

        function startCategory(categoryKey) {
            currentCategoryKey = categoryKey;
            generatedQuestions = generateQuizData(categoryKey); 
            questionIndex = 0;
            score = 0;
            
            document.getElementById('category-title').innerText = rawMenuData[categoryKey].title;
            hideAllScreens();
            screens.quiz.classList.remove('hidden');
            setTimeout(() => screens.quiz.classList.add('fade-in'), 10);
            
            loadQuestion();
        }

        function restartCategory() {
            startCategory(currentCategoryKey);
        }

        function updateProgress() {
            const progressPercent = ((questionIndex) / generatedQuestions.length) * 100;
            document.getElementById('progress-bar').style.width = `${progressPercent}%`;
            document.getElementById('progress-text').innerText = `Рівень ${questionIndex + 1} / ${generatedQuestions.length}`;
        }

        function loadQuestion() {
            updateProgress();
            const qData = generatedQuestions[questionIndex];
            document.getElementById('question-text').innerText = qData.question;
            
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            
            qData.options.forEach((optionText, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = optionText;
                btn.onclick = () => checkAnswer(index);
                optionsContainer.appendChild(btn);
            });
        }

        function checkAnswer(selectedIndex) {
            const qData = generatedQuestions[questionIndex];
            if (selectedIndex === qData.correct) {
                score++;
            }
            
            questionIndex++;
            if (questionIndex < generatedQuestions.length) {
                loadQuestion();
            } else {
                showResults();
            }
        }

        function showResults() {
            hideAllScreens();
            screens.result.classList.remove('hidden');
            setTimeout(() => screens.result.classList.add('fade-in'), 10);
            
            const percentage = Math.round((score / generatedQuestions.length) * 100);
            let message = "";
            if (percentage === 100) message = "ура все вірно! ";
            else if (percentage >= 80) message = "майже все вірно.";
            else if (percentage >= 50) message = "плюс мінус вірно";
            else message = "взагалі не вірно плакать хочеться.";

            document.getElementById('score-display').innerText = `${score} / ${generatedQuestions.length}`;
            document.getElementById('score-message').innerText = message;
        }
